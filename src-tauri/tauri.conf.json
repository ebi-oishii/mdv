{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mddiff",
  "version": "0.2.1-alpha.1",
  "identifier": "dev.ebioishii.mddiff",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "mddiff",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "version": "0.2.1.1"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown Document",
        "description": "Markdown text file",
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["mddiff"],
        "name": "mddiff package",
        "description": "mddiff portable package with embedded Git history",
        "role": "Editor",
        "mimeType": "application/x-mddiff"
      }
    ]
  }
}
